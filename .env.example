# Growatt to Home Assistant Bridge - environment variables
# Copy this file to .env and fill in your values

# Growatt portal URL for your region (default: US/Canada)
# US/Canada:  https://shiner-us.growatt.com
# Global:     https://server.growatt.com
# EU:         https://server-api.growatteurope.com
# Australia:  https://server-api.growattcloud.com.au
BASE_URL=https://shiner-us.growatt.com

# Growatt portal credentials
GROWATT_USERNAME=you@example.com
GROWATT_PASSWORD=yourpassword

# Your inverter serial number (found in the Growatt portal under Devices)
GROWATT_DEVICE_SN=

# Home Assistant URL (use local IP, not a Cloudflare tunnel)
HA_URL=http://homeassistant.local:8123

# Home Assistant long-lived access token
# Generate at: HA Profile - Long-Lived Access Tokens
HA_TOKEN=

# Poll interval in seconds (default: 300 = 5 minutes, minimum: 60)
POLL_INTERVAL_SECONDS=300
